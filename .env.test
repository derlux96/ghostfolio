# Ghostfolio Test Environment
COMPOSE_PROJECT_NAME=ghostfolio-test

# CACHE
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=ghostfolio-test-redis

# POSTGRES
POSTGRES_DB=ghostfolio-test
POSTGRES_USER=ghostfolio
POSTGRES_PASSWORD=ghostfolio-test-pw
DATABASE_URL=postgresql://ghostfolio:ghostfolio-test-pw@localhost:5433/ghostfolio-test?connect_timeout=300&sslmode=prefer

# VARIOUS
ACCESS_TOKEN_SALT=ghostfolio-test-access-token-salt-32chars!!
JWT_SECRET_KEY=ghostfolio-test-jwt-secret-key-32chars!!

# DEV
NX_ADD_PLUGINS=false
NODE_ENV=development

# Ghostfolio specific
GF_API_HOST=http://localhost:3333
GF_DATA_SOURCE=YAHOO
GF_EXCHANGE_RATES_API_KEY=demo
